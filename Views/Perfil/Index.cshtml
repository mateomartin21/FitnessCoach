@model FitnessCoach.Models.UsuarioPerfil

@{
    ViewData["Title"] = "Configuración de Perfil - FitnessCoach";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Actualizar Datos Antropométricos</h5>
                </div>
                <div class="card-body">
                    <form asp-controller="Perfil" asp-action="GuardarPerfil" method="post">
                        
                        <div class="mb-3">
                            <label for="Nombre" class="form-label">Nombre Completo</label>
                            <input type="text" class="form-control" id="Nombre" name="Nombre" value="@Model.Nombre" required />
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label for="Edad" class="form-label">Edad (años)</label>
                                <input type="number" class="form-control" id="Edad" name="Edad" value="@Model.Edad" required />
                            </div>
                            <div class="col-6 mb-3">
                                <label for="PesoKg" class="form-label">Peso Actual (kg)</label>
                                <input type="number" step="0.1" class="form-control" id="PesoKg" name="PesoKg" value="@Model.PesoKg" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="EstaturaCm" class="form-label">Estatura (cm)</label>
                            <input type="number" class="form-control" id="EstaturaCm" name="EstaturaCm" value="@Model.EstaturaCm" required />
                        </div>

                        <div class="mb-3">
                            <label for="TipoObjetivo" class="form-label">Objetivo Fitness Principal</label>
                            <select class="form-select" id="TipoObjetivo" name="TipoObjetivo">
                                <option value="Perder">Pérdida de Grasa (Déficit Calórico)</option>
                                <option value="Recomp">Recomposición Corporal & Fuerza (Mantenimiento)</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Calcular y Guardar Configuración</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Resultados del Plan Personalizado</h5>
                </div>
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h3 class="text-success mb-1">@Model.Nombre</h3>
                        <p class="text-muted small">Estado actual del perfil basado en ciencia deportiva</p>
                        <hr />

                        <div class="p-3 mb-3 bg-light rounded border">
                            <h6 class="text-uppercase text-muted font-weight-bold small">Objetivo Seleccionado</h6>
                            <p class="h5 mb-0 text-dark">@(Model.ObjetivoActual?.Nombre ?? "No definido")</p>
                        </div>

                        <div class="p-3 mb-3 bg-light rounded border">
                            <h6 class="text-uppercase text-muted font-weight-bold small">Distribución Base Estimada</h6>
                            <ul class="list-unstyled mb-0 mt-2">
                                <li>• Entrenamiento de fuerza recomendado: 4 días por semana</li>
                                <li>• Enfoque principal: Preservación de masa muscular magra</li>
                            </ul>
                        </div>
                    </div>

                    <div class="p-4 bg-success bg-opacity-10 rounded border border-success text-center mt-3">
                        <span class="text-uppercase text-muted small d-block mb-1">Presupuesto Energético Diario</span>
                        <span class="display-5 d-block font-weight-bold text-success">@ViewBag.CaloriasRecomendadas</span>
                        <span class="h4 text-success">kcal / día</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>