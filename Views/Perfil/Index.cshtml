@model FitnessCoach.Domain.Models.UsuarioPerfil
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header py-3" style="border-left: 4px solid var(--fc-primary);">
                <h5 class="mb-0"><i class="fas fa-user-edit me-2" style="color:var(--fc-primary);"></i>Actualizar Perfil</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Perfil" asp-action="GuardarPerfil" method="post">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" name="Nombre" value="@Model.Nombre" required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Edad</label>
                            <input type="number" class="form-control" name="Edad" value="@Model.Edad" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Peso (kg)</label>
                            <input type="number" step="0.1" class="form-control" name="PesoKg" value="@Model.PesoKg" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estatura (cm)</label>
                        <input type="number" class="form-control" name="EstaturaCm" value="@Model.EstaturaCm" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Objetivo Fitness</label>
                        <select class="form-select" name="TipoObjetivo">
                            <option value="Perder">?? Perdida de Grasa</option>
                            <option value="Musculo">?? Ganar Musculo</option>
                            <option value="Recomp">? Recomposicion Corporal</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="fas fa-save me-2"></i>Guardar y Calcular
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header py-3" style="border-left: 4px solid #00d4ff;">
                <h5 class="mb-0"><i class="fas fa-chart-bar me-2" style="color:#00d4ff;"></i>Tu Plan Personalizado</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h3 class="fw-bold mb-1" style="color:var(--fc-primary);">@Model.Nombre</h3>
                    <p class="text-muted small mb-3">Resultados basados en formula Mifflin-St Jeor</p>

                    <div class="p-3 mb-3 rounded" style="background:#0f0f1a; border:1px solid #2a2a4a;">
                        <small class="text-muted text-uppercase">Objetivo Actual</small>
                        <p class="h5 mb-0 mt-1">@(Model.ObjetivoActual?.Nombre ?? "No definido")</p>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-4">
                            <div class="p-2 rounded text-center" style="background:#0f0f1a; border:1px solid #2a2a4a;">
                                <small class="text-muted d-block">Edad</small>
                                <strong>@Model.Edad ańos</strong>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded text-center" style="background:#0f0f1a; border:1px solid #2a2a4a;">
                                <small class="text-muted d-block">Peso</small>
                                <strong>@Model.PesoKg kg</strong>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded text-center" style="background:#0f0f1a; border:1px solid #2a2a4a;">
                                <small class="text-muted d-block">Estatura</small>
                                <strong>@Model.EstaturaCm cm</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4 rounded text-center mt-2" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border: 2px solid var(--fc-primary);">
                    <small class="text-muted text-uppercase d-block mb-1">Calorias Diarias Recomendadas</small>
                    <span class="display-4 fw-bold" style="color:var(--fc-primary);">@ViewBag.CaloriasRecomendadas</span>
                    <span class="h5 text-muted ms-1">kcal/dia</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a asp-controller="Rutinas" asp-action="Index" class="btn btn-primary px-5">
        <i class="fas fa-fire me-2"></i>Ver Mi Rutina Personalizada
    </a>
</div>
