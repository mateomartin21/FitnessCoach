@model FitnessCoach.Models.Entrenamiento.Rutina

@{
    ViewData["Title"] = "Mi Plan de Entrenamiento";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="display-6 font-weight-bold text-dark">@Model.NombreRutina</h2>
        <p class="text-muted">Nivel sugerido: <span class="badge bg-primary fs-6">@Model.Nivel</span></p>
    </div>

    <div class="accordion shadow-sm" id="accordionRutina">
        @for (int i = 0; i < Model.Dias.Count; i++)
        {
            var dia = Model.Dias[i];
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading-@i">
                    <button class="accordion-button @(i == 0 ? "" : "collapsed") bg-light text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@i" aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="collapse-@i">
                        <strong>@dia.NombreDia</strong> &nbsp;-&nbsp; @dia.Enfoque
                    </button>
                </h2>
                <div id="collapse-@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="heading-@i" data-bs-parent="#accordionRutina">
                    <div class="accordion-body">
                        
                        @if (dia.Ejercicios.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-bordered align-middle">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Ejercicio</th>
                                            <th class="text-center">Series</th>
                                            <th class="text-center">Repeticiones</th>
                                            <th>Notas Adicionales</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ej in dia.Ejercicios)
                                        {
                                            <tr>
                                                <td class="fw-bold">@ej.Nombre</td>
                                                <td class="text-center">@ej.Series</td>
                                                <td class="text-center">@ej.Repeticiones</td>
                                                <td class="text-muted small">@(string.IsNullOrEmpty(ej.Notas) ? "-" : ej.Notas)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success d-flex align-items-center" role="alert">
                                <div>
                                    <strong>¡Día de Descanso!</strong> Recupera energías, la alimentación es clave hoy.
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
</div>