@{
    ViewData["Title"] = "Inicio";
}

<div class="fc-hero row align-items-center py-5 mb-5">
    <div class="col-md-7">
        <div class="fc-tag mb-3">ENTRENAMIENTO INTELIGENTE</div>
        <h1 class="fc-hero-title">Alcanza tu<br/><span style="color:#ff6b35;">maximo potencial</span></h1>
        <p class="fc-hero-sub mt-3 mb-4">Rutinas cientificas generadas segun tu objetivo. Calentamiento y enfriamiento automaticos. Todo adaptado a ti.</p>
        <div class="d-flex gap-3 flex-wrap">
            <a asp-controller="Perfil" asp-action="Index" class="btn fc-btn-primary px-4 py-2">
                <i class="fas fa-user-cog me-2"></i>Configurar Perfil
            </a>
            <a asp-controller="Rutinas" asp-action="Index" class="btn fc-btn-outline px-4 py-2">
                <i class="fas fa-list-check me-2"></i>Ver Rutina
            </a>
        </div>
    </div>
    <div class="col-md-5 text-center mt-4 mt-md-0">
        <div class="fc-wolf-container">
            <svg width="280" height="280" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="fc-wolf">
                <!-- Cuerpo -->
                <ellipse cx="100" cy="145" rx="45" ry="35" fill="#3a3a6a"/>
                <!-- Brazos musculosos -->
                <ellipse cx="60" cy="140" rx="14" ry="22" fill="#3a3a6a" transform="rotate(-15 60 140)"/>
                <ellipse cx="140" cy="140" rx="14" ry="22" fill="#3a3a6a" transform="rotate(15 140 140)"/>
                <!-- Manos -->
                <ellipse cx="52" cy="158" rx="10" ry="8" fill="#2a2a4a"/>
                <ellipse cx="148" cy="158" rx="10" ry="8" fill="#2a2a4a"/>
                <!-- Cabeza -->
                <ellipse cx="100" cy="90" rx="35" ry="32" fill="#3a3a6a"/>
                <!-- Orejas -->
                <path d="M72 65 Q65 42 75 38 Q82 50 80 65Z" fill="#3a3a6a"/>
                <path d="M128 65 Q135 42 125 38 Q118 50 120 65Z" fill="#3a3a6a"/>
                <path d="M74 63 Q68 46 76 43 Q81 52 80 63Z" fill="#ff6b35"/>
                <path d="M126 63 Q132 46 124 43 Q119 52 120 63Z" fill="#ff6b35"/>
                <!-- Cara -->
                <ellipse cx="100" cy="98" rx="22" ry="18" fill="#2a2a4a"/>
                <!-- Ojos -->
                <circle cx="90" cy="85" r="6" fill="white"/>
                <circle cx="110" cy="85" r="6" fill="white"/>
                <circle cx="91" cy="86" r="3.5" fill="#ff6b35"/>
                <circle cx="111" cy="86" r="3.5" fill="#ff6b35"/>
                <circle cx="92" cy="85" r="1.5" fill="#0f0f1a"/>
                <circle cx="112" cy="85" r="1.5" fill="#0f0f1a"/>
                <!-- Nariz -->
                <ellipse cx="100" cy="95" rx="5" ry="3" fill="#ff6b35"/>
                <!-- Boca -->
                <path d="M90 103 Q100 110 110 103" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/>
                <!-- Colmillos -->
                <path d="M95 103 L93 109" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M105 103 L107 109" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                <!-- Pecho muscular -->
                <ellipse cx="88" cy="138" rx="15" ry="12" fill="#2a2a4a"/>
                <ellipse cx="112" cy="138" rx="15" ry="12" fill="#2a2a4a"/>
                <!-- Pesa en mano derecha -->
                <rect x="140" y="160" width="4" height="20" fill="#ff6b35" rx="2"/>
                <rect x="135" y="160" width="14" height="5" fill="#888" rx="2"/>
                <rect x="135" y="175" width="14" height="5" fill="#888" rx="2"/>
                <!-- Insignia -->
                <circle cx="100" cy="125" r="8" fill="#ff6b35"/>
                <text x="100" y="129" text-anchor="middle" fill="white" font-size="9" font-weight="bold">FC</text>
                <!-- Cola -->
                <path d="M145 155 Q165 140 160 125 Q155 138 145 148Z" fill="#3a3a6a"/>
            </svg>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(255,107,53,0.15); color:#ff6b35;">
                <i class="fas fa-fire-flame-curved fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Quema de Grasa</h5>
            <p class="text-muted small mb-0">Rutinas Full Body con cardio integrado. 3 dias a la semana, maxima eficiencia calorica.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(0,212,255,0.15); color:#00d4ff;">
                <i class="fas fa-arrows-rotate fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Recomposicion Corporal</h5>
            <p class="text-muted small mb-0">Equilibrio entre fuerza e hipertrofia. 4 dias Torso/Pierna para resultados duales.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(255,215,0,0.15); color:#ffd700;">
                <i class="fas fa-trophy fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Ganancia Muscular</h5>
            <p class="text-muted small mb-0">Hipertrofia maxima en 5 dias. Volumen y tension mecanica para crecimiento optimo.</p>
        </div>
    </div>
</div>

<div class="fc-info-bar row align-items-center p-4 mb-2">
    <div class="col-md-3 text-center border-end fc-stat">
        <div class="fc-stat-num">3</div>
        <div class="fc-stat-label">Objetivos Disponibles</div>
    </div>
    <div class="col-md-3 text-center border-end fc-stat">
        <div class="fc-stat-num">GOF</div>
        <div class="fc-stat-label">Patrones Implementados</div>
    </div>
    <div class="col-md-3 text-center border-end fc-stat">
        <div class="fc-stat-num">4</div>
        <div class="fc-stat-label">Capas Hexagonales</div>
    </div>
    <div class="col-md-3 text-center fc-stat">
        <div class="fc-stat-num">AI</div>
        <div class="fc-stat-label">Gemini Ready</div>
    </div>
</div>
