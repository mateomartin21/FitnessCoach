@{
    ViewData["Title"] = "Inicio";
}

<div class="fc-hero row align-items-center py-5 mb-5">
    <div class="col-md-7">
        <div class="fc-tag mb-3">ENTRENAMIENTO INTELIGENTE</div>
        <h1 class="fc-hero-title">Alcanza tu<br/><span style="color:#ff6b35;">maximo potencial</span></h1>
        <p class="fc-hero-sub mt-3 mb-4">Rutinas cientificas generadas segun tu objetivo. Calentamiento y enfriamiento automaticos. Todo adaptado a ti.</p>
        <div class="d-flex gap-3 flex-wrap">
            <a asp-controller="Perfil" asp-action="Index" class="btn fc-btn-primary px-4 py-2">
                <i class="fas fa-user-cog me-2"></i>Configurar Perfil
            </a>
            <a asp-controller="Rutinas" asp-action="Index" class="btn fc-btn-outline px-4 py-2">
                <i class="fas fa-list-check me-2"></i>Ver Rutina
            </a>
        </div>
    </div>
    <div class="col-md-5 text-center mt-4 mt-md-0">
        <div class="col-md-5 text-center mt-4 mt-md-0">
            <img src="~/images/branding/principal.png"
                 alt="FitnessCoach Hero"
                 class="img-fluid rounded-lg shadow-lg"
                 style="max-width: 100%; height: auto; border-radius: 15px; border: 2px solid #ff6b35;">
        </div>

    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(255,107,53,0.15); color:#ff6b35;">
                <i class="fas fa-fire-flame-curved fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Quema de Grasa</h5>
            <p class="text-muted small mb-0">Rutinas Full Body con cardio integrado. 3 dias a la semana, maxima eficiencia calorica.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(0,212,255,0.15); color:#00d4ff;">
                <i class="fas fa-arrows-rotate fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Recomposicion Corporal</h5>
            <p class="text-muted small mb-0">Equilibrio entre fuerza e hipertrofia. 4 dias Torso/Pierna para resultados duales.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="fc-feature-card h-100">
            <div class="fc-feature-icon" style="background: rgba(255,215,0,0.15); color:#ffd700;">
                <i class="fas fa-trophy fa-lg"></i>
            </div>
            <h5 class="mt-3 mb-2">Ganancia Muscular</h5>
            <p class="text-muted small mb-0">Hipertrofia maxima en 5 dias. Volumen y tension mecanica para crecimiento optimo.</p>
        </div>
    </div>
</div>


</div>
